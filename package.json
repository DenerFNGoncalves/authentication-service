{
	"name": "authservice",
	"version": "1.0.0",
	"description": "Project designed to perform authentication services",
	"keywords": [
		"auth",
		"authentication"
	],
	"license": "ISC",
	"author": "Dener F. N. Gonçalves",
	"type": "module",
	"main": "build/index.js",
	"scripts": {
		"start": "node build/index.js",
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.build.json",
		"build:tests": "tsc -p tsconfig.build-tests.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"fix": "prettier . --write && eslint . --fix",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
		"test:u": "npm test tests/unit",
		"test:i": "npm test tests/integration",
		"test:watch": "npm test -- --watch",
		"authdb:generate": "node scripts/drizzle/auth.generate-migration.cjs",
		"authdb:migrate": "drizzle-kit migrate --config ./scripts/drizzle/auth.drizzle-config.ts",
		"authdb:studio": "drizzle-kit studio --config ./scripts/drizzle/auth.drizzle-config.ts",
		"auditdb:generate": "node scripts/drizzle/audit.generate-migration.cjs",
		"auditdb:migrate": "drizzle-kit migrate --config ./scripts/drizzle/audit.drizzle-config.ts",
		"auditdb:studio": "drizzle-kit studio --config ./scripts/drizzle/audit.drizzle-config.ts"
	},
	"devDependencies": {
		"@swc/core": "^1.15.10",
		"@swc/jest": "^0.2.39",
		"@testcontainers/postgresql": "^11.12.0",
		"@types/bcrypt": "^6.0.0",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.0.10",
		"@types/pg": "^8.16.0",
		"dotenv": "^17.2.4",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.39.2",
		"jest": "^30.2.0",
		"prettier": "^3.8.1",
		"testcontainers": "^11.12.0",
		"tsx": "^4.21.0",
		"typescript": "5.9",
		"typescript-eslint": "^8.54.0"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"drizzle-orm": "^0.45.1",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"pino": "^10.3.1",
		"postgres": "^3.4.8",
		"zod": "^4.3.6"
	}
}
